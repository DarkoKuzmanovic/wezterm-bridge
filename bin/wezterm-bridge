#!/usr/bin/env bash
set -euo pipefail

VERSION="2.0.0"
LABEL_DIR="/tmp/wezterm-bridge-${UID:-$(id -u)}/labels"
GUARD_PREFIX="/tmp/wezterm-bridge-${UID:-$(id -u)}/read"
LOG_FILE="/tmp/wezterm-bridge-${UID:-$(id -u)}/bridge.log"
CURSOR_DIR="/tmp/wezterm-bridge-${UID:-$(id -u)}/cursors"
LOCK_DIR="/tmp/wezterm-bridge-${UID:-$(id -u)}/locks"
JSON_OUTPUT=false

json_escape() {
    local val="$1"
    val="${val//\\/\\\\}"
    val="${val//\"/\\\"}"
    val="${val//$'\n'/\\n}"
    val="${val//$'\t'/\\t}"
    printf '%s' "$val"
}

json_ok() {
    local cmd="$1"; shift
    printf '{"status":"ok","command":"%s"' "$cmd"
    while [[ $# -gt 0 ]]; do
        local key="${1%%=*}" val="${1#*=}"
        val="$(json_escape "$val")"
        printf ',"%s":"%s"' "$key" "$val"
        shift
    done
    printf '}\n'
}

json_error() {
    local msg
    msg="$(json_escape "$1")"
    printf '{"status":"error","message":"%s"}\n' "$msg" >&2
    exit 1
}

log_event() {
    local actor="${WEZTERM_PANE:-?}"
    local direction="$1"
    local target="$2"
    local cmd="$3"
    local summary="${4:-}"
    ensure_dirs
    local line
    line="$(date -Iseconds) ${actor}${direction}${target} ${cmd}"
    [[ -n "$summary" ]] && line+=" $summary"
    printf '%s\n' "$line" >> "$LOG_FILE"
}

die() {
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_error "$*"
    else
        echo "error: $*" >&2
        exit 1
    fi
}

require_args() {
    local need="$1" have="$2" cmd="$3"
    if (( have < need )); then
        die "'$cmd' requires at least $need argument(s). Run: wezterm-bridge help"
    fi
}

_require_posint() { [[ "$1" =~ ^[0-9]+$ ]] && (( $1 > 0 )) || die "$2"; }

require_wezterm() {
    command -v wezterm >/dev/null 2>&1 || die "wezterm is not installed"
}

require_jq() {
    command -v jq >/dev/null 2>&1 || die "jq is not installed. Install with: sudo pacman -S jq"
}

ensure_dirs() {
    [[ -d "$LABEL_DIR" ]] && return
    local base="/tmp/wezterm-bridge-${UID:-$(id -u)}"
    mkdir -p "$LABEL_DIR" "$CURSOR_DIR" "$LOCK_DIR"
    chmod 700 "$base"
}

save_cursor() {
    local pane_id="$1" content="$2"
    local line_count
    line_count="$(printf '%s\n' "$content" | wc -l | tr -d ' ')"
    local last_line
    last_line="$(printf '%s\n' "$content" | tail -1)"
    local last_line_hash
    last_line_hash="$(printf '%s' "$last_line" | cksum | cut -d' ' -f1)"
    printf '%s:%s\n' "$line_count" "$last_line_hash" > "$CURSOR_DIR/$pane_id"
}

read_since_cursor() {
    local pane_id="$1" content="$2"
    local cursor_file="$CURSOR_DIR/$pane_id"
    if [[ ! -f "$cursor_file" ]]; then
        printf '%s\n' "$content"
        return
    fi
    local saved_count saved_hash
    IFS=: read -r saved_count saved_hash < "$cursor_file"

    local total_lines
    total_lines="$(printf '%s\n' "$content" | wc -l | tr -d ' ')"

    if (( saved_count > total_lines )); then
        printf '%s\n' "$content"
        return
    fi

    local line_at_cursor
    line_at_cursor="$(printf '%s\n' "$content" | sed -n "${saved_count}p")"
    local current_hash
    current_hash="$(printf '%s' "$line_at_cursor" | cksum | cut -d' ' -f1)"

    if [[ "$current_hash" == "$saved_hash" ]]; then
        if (( saved_count < total_lines )); then
            printf '%s\n' "$content" | tail -n +"$(( saved_count + 1 ))"
        else
            echo "(no new output)"
        fi
    else
        echo "[cursor mismatch — showing all content]"
        printf '%s\n' "$content"
    fi
}

check_lock() {
    local target="$1"
    local lock_file="$LOCK_DIR/$target"
    if [[ -f "$lock_file" ]]; then
        local owner ts timeout_secs
        IFS=: read -r owner ts timeout_secs < "$lock_file"
        local now
        now="$(date +%s)"
        local expires=$(( ts + timeout_secs ))
        if (( now < expires )) && [[ "$owner" != "${WEZTERM_PANE:-}" ]]; then
            local remaining=$(( expires - now ))
            die "pane $target locked by pane $owner (expires in ${remaining}s)"
        fi
        if (( now >= expires )); then
            rm -f "$lock_file"
        fi
    fi
}

require_read() {
    [[ -f "${GUARD_PREFIX}-${1}" ]] || die "must read pane $1 before interacting. Run: wezterm-bridge read $1"
}

_dedup_label() {
    local label="$1" f
    for f in "$LABEL_DIR"/*; do
        [[ -f "$f" ]] || continue
        if [[ "$(cat "$f")" == "$label" ]]; then rm -f "$f"; fi
    done
}

resolve_label() {
    ensure_dirs
    local label="$1"
    for f in "$LABEL_DIR"/*; do
        [[ -f "$f" ]] || continue
        if [[ "$(cat "$f")" == "$label" ]]; then
            basename "$f"
            return 0
        fi
    done
    die "no pane found with label '$label'"
}

resolve_target() {
    local target="$1"
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        echo "$target"
        return
    fi
    resolve_label "$target"
}

_expand_var() {
    local line="$1" i="$2" len="$3" var_lookup="$4"
    local next="${line:i+1:1}"
    [[ "$next" == '(' ]] && die "\$(...) command substitution is not allowed in workflow files"
    [[ "$next" == '{' ]] && die "\${...} brace expansion is not allowed in workflow files"
    local varname="" j=$(( i + 1 ))
    while (( j < len )) && [[ "${line:j:1}" =~ [A-Za-z0-9_] ]]; do
        varname+="${line:j:1}"; (( j++, 1 ))
    done
    [[ -z "$varname" ]] && die "bare \$ in workflow file (use \\\$ for literal dollar)"
    _EXPAND_END=$j
    if ! _EXPAND_VAL="$("$var_lookup" "$varname")"; then
        die "undefined variable '\$$varname' in workflow file"
    fi
}

tokenize_line() {
    local line="$1" var_lookup="$2"
    TOKENS=()
    local i=0 len=${#line} token="" in_quotes=false

    while (( i < len )); do
        local ch="${line:i:1}"

        if [[ "$ch" == "'" ]] && ! $in_quotes; then
            die "single quotes are not supported in workflow files"
        fi
        [[ "$ch" == '`' ]] && die "backtick substitution is not allowed in workflow files"

        if $in_quotes; then
            if [[ "$ch" == '\' ]]; then
                local next="${line:i+1:1}"
                case "$next" in
                    '"')  token+='"' ;;
                    '\') token+='\' ;;
                    '$') token+='$' ;;
                    *)    die "invalid escape '\\$next' in workflow file (allowed: \\\", \\\\, \\\$)" ;;
                esac
                (( i += 2 ))
            elif [[ "$ch" == '"' ]]; then
                in_quotes=false
                (( i++, 1 ))
            elif [[ "$ch" == '$' ]]; then
                _expand_var "$line" "$i" "$len" "$var_lookup"
                token+="$_EXPAND_VAL"; i=$_EXPAND_END
            else
                token+="$ch"; (( i++, 1 ))
            fi
        else
            if [[ "$ch" == '"' ]]; then
                in_quotes=true; (( i++, 1 ))
            elif [[ "$ch" == ' ' || "$ch" == $'\t' ]]; then
                [[ -n "$token" ]] && TOKENS+=("$token") && token=""
                (( i++, 1 ))
            elif [[ "$ch" == '\' ]]; then
                local next="${line:i+1:1}"
                if [[ "$next" == '$' ]]; then
                    token+='$'; (( i += 2 ))
                else
                    die "invalid escape '\\$next' outside quotes in workflow file"
                fi
            elif [[ "$ch" == '$' ]]; then
                _expand_var "$line" "$i" "$len" "$var_lookup"
                token+="$_EXPAND_VAL"; i=$_EXPAND_END
            else
                token+="$ch"; (( i++, 1 ))
            fi
        fi
    done

    $in_quotes && die "unterminated quote in workflow file"
    [[ -n "$token" ]] && TOKENS+=("$token")
}

parse_workflow() {
    local filepath="$1"
    [[ -f "$filepath" ]] || die "workflow file not found: $filepath"

    WF_NAME=""
    WF_DESCRIPTION=""
    WF_BODY=()
    declare -gA WF_VARS=()

    local line_num=0
    while IFS= read -r line || [[ -n "$line" ]]; do
        (( line_num++, 1 ))

        [[ -z "$line" || "$line" =~ ^[[:space:]]*$ ]] && continue

        if [[ "$line" =~ ^'#!' ]]; then
            local content="${line#'#!'}"
            content="${content#"${content%%[![:space:]]*}"}"  # trim leading whitespace
            if [[ "$content" =~ ^name:[[:space:]]*(.*) ]]; then
                WF_NAME="${BASH_REMATCH[1]}"
            elif [[ "$content" =~ ^description:[[:space:]]*(.*) ]]; then
                WF_DESCRIPTION="${BASH_REMATCH[1]}"
            elif [[ "$content" =~ ^var:[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)=(.*) ]]; then
                WF_VARS["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
            else
                die "unknown header directive at line $line_num: $content"
            fi
            continue
        fi

        [[ "$line" =~ ^[[:space:]]*'#' ]] && continue

        line="${line#"${line%%[![:space:]]*}"}"


        if [[ "$line" =~ ^run([[:space:]]|$) ]]; then
            die "nested 'run' is not allowed in workflow files (line $line_num)"
        fi

        WF_BODY+=("$line")
    done < "$filepath"
}

wf_var_lookup() {
    local name="$1"
    if [[ -v "WF_VARS[$name]" ]]; then
        printf '%s' "${WF_VARS[$name]}"
    else
        return 1
    fi
}

resolve_workflow() {
    local name="$1"

    if [[ "$name" == */* || "$name" == *.wb ]]; then
        [[ -f "$name" ]] || die "workflow file not found: $name"
        echo "$name"
        return
    fi

    local project_path=".wezterm-bridge/workflows/${name}.wb"
    if [[ -f "$project_path" ]]; then
        echo "$(pwd)/.wezterm-bridge/workflows/${name}.wb"
        return
    fi

    local global_path="$HOME/.wezterm-bridge/workflows/${name}.wb"
    if [[ -f "$global_path" ]]; then
        echo "$global_path"
        return
    fi

    die "workflow '$name' not found. Searched: ./$project_path, $global_path"
}

_wf_valid_commands=(list read type keys message name resolve id spawn lock unlock wait log doctor)

cmd_run() {
    local check_only=false
    if [[ "${1:-}" == "--check" ]]; then
        check_only=true
        shift
    fi

    [[ $# -ge 1 ]] || die "'run' requires a workflow name or path. Run: wezterm-bridge help"

    local wf_path
    wf_path="$(resolve_workflow "$1")"
    shift

    parse_workflow "$wf_path"

    for arg in "$@"; do
        if [[ "$arg" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
            local oname="${BASH_REMATCH[1]}"
            local oval="${BASH_REMATCH[2]}"
            if [[ ! -v "WF_VARS[$oname]" ]]; then
                die "unknown variable override '$oname' (not declared in workflow)"
            fi
            WF_VARS["$oname"]="$oval"
        else
            die "invalid argument '$arg' (expected VAR=value)"
        fi
    done

    local total=${#WF_BODY[@]}
    local wf_label="${WF_NAME:-$(basename "$wf_path" .wb)}"

    if $check_only; then
        _wf_check "$wf_label" "$total"
        return
    fi

    local last_read_output=""
    local step=0

    for body_line in "${WF_BODY[@]}"; do
        (( step++, 1 ))
        tokenize_line "$body_line" wf_var_lookup
        local command="${TOKENS[0]}"
        local args=("${TOKENS[@]:1}")

        local valid=false
        for vc in "${_wf_valid_commands[@]}"; do
            [[ "$vc" == "$command" ]] && valid=true && break
        done
        $valid || die "unknown command '$command' in workflow '$wf_label' (step $step/$total)"

        echo "[workflow:$wf_label] step $step/$total: $body_line" >&2

        local step_output
        if ! step_output="$(cmd_"$command" "${args[@]}" 2>&1)"; then
            if [[ "$JSON_OUTPUT" == "true" ]]; then
                local emsg
                emsg="$(json_escape "step $step/$total failed: $body_line: $step_output")"
                printf '{"status":"error","command":"run","workflow":"%s","failed_step":%d,"total_steps":%d,"message":"%s"}\n' \
                    "$wf_label" "$step" "$total" "$emsg"
                exit 1
            else
                echo "[workflow:$wf_label] step $step/$total failed: $body_line" >&2
                echo "$step_output" >&2
                exit 1
            fi
        fi

        if [[ "$command" == "read" ]]; then
            last_read_output="$step_output"
        fi

        if [[ "$command" != "read" && -n "$step_output" ]]; then
            echo "$step_output" >&2
        fi
    done

    if [[ "$JSON_OUTPUT" == "true" ]]; then
        local encoded_result
        encoded_result="$(json_escape "$last_read_output")"
        printf '{"status":"ok","command":"run","workflow":"%s","steps":%d,"result":"%s"}\n' \
            "$wf_label" "$total" "$encoded_result"
    elif [[ -n "$last_read_output" ]]; then
        printf '%s\n' "$last_read_output"
    fi
}

_wf_check() {
    local wf_label="$1"
    local total="$2"
    local step=0
    local -A check_labels=()

    if [[ -d "$LABEL_DIR" ]]; then
        for lfile in "$LABEL_DIR"/*; do
            [[ -f "$lfile" ]] || continue
            local lname
            lname="$(cat "$lfile")"
            check_labels["$lname"]=1
        done
    fi

    for body_line in "${WF_BODY[@]}"; do
        (( step++, 1 ))
        tokenize_line "$body_line" wf_var_lookup
        local command="${TOKENS[0]}"

        local valid=false
        for vc in "${_wf_valid_commands[@]}"; do
            [[ "$vc" == "$command" ]] && valid=true && break
        done
        $valid || die "unknown command '$command' in workflow '$wf_label' (step $step/$total)"

        if [[ "$command" == "spawn" ]]; then
            check_labels["${TOKENS[1]}"]=1
        elif [[ "$command" == "name" ]] && [[ ${#TOKENS[@]} -ge 3 ]]; then
            check_labels["${TOKENS[2]}"]=1
        fi
    done

    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "run" "workflow=$wf_label" "mode=check" "steps=$total"
    else
        echo "workflow '$wf_label' is valid ($total steps)" >&2
    fi
}

cmd_id() {
    if [[ -z "${WEZTERM_PANE:-}" ]]; then
        die "not running inside a WezTerm pane (\$WEZTERM_PANE not set)"
    fi
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "id" "pane_id=$WEZTERM_PANE"
    else
        echo "$WEZTERM_PANE"
    fi
}

cmd_name() {
    require_args 2 $# "name"
    local target="$1"
    local label="$2"
    if [[ ! "$target" =~ ^[0-9]+$ ]]; then
        target="$(resolve_label "$target")"
    fi
    ensure_dirs
    _dedup_label "$label"
    printf '%s\n' "$label" > "$LABEL_DIR/$target"
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "name" "pane_id=$target" "label=$label"
    else
        echo "pane $target labeled '$label'"
    fi
    log_event ">" "$target" "name" "$label"
}

cmd_resolve() {
    require_args 1 $# "resolve"
    local pane_id
    pane_id="$(resolve_label "$1")"
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "resolve" "pane_id=$pane_id" "label=$1"
    else
        echo "$pane_id"
    fi
}

cmd_type() {
    require_args 2 $# "type"
    local target
    target="$(resolve_target "$1")"
    require_read "$target"
    check_lock "$target"
    require_wezterm
    shift
    local enter=false
    if [[ "${1:-}" == "--enter" ]]; then
        enter=true
        shift
    fi
    [[ $# -eq 0 ]] && die "type requires text argument"
    printf '%s' "$*" | wezterm cli send-text --pane-id "$target" --no-paste
    if [[ "$enter" == "true" ]]; then
        sleep 0.05
        printf '\r' | wezterm cli send-text --pane-id "$target" --no-paste
    fi
    rm -f "${GUARD_PREFIX}-${target}"
    log_event ">" "$target" "type" "$*"
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "type" "pane_id=$target"
    fi
}

cmd_keys() {
    require_args 2 $# "keys"
    local target
    target="$(resolve_target "$1")"
    require_read "$target"
    check_lock "$target"
    shift
    require_wezterm
    local seq=""
    for key in "$@"; do
        case "$key" in
            Enter)   seq+='\r' ;;
            Escape)  seq+='\x1b' ;;
            Tab)     seq+='\t' ;;
            C-c)     seq+='\x03' ;;
            C-d)     seq+='\x04' ;;
            C-z)     seq+='\x1a' ;;
            C-l)     seq+='\x0c' ;;
            C-a)     seq+='\x01' ;;
            C-e)     seq+='\x05' ;;
            C-u)     seq+='\x15' ;;
            C-k)     seq+='\x0b' ;;
            C-w)     seq+='\x17' ;;
            Space)   seq+=' ' ;;
            BSpace)  seq+='\x7f' ;;
            Up)      seq+='\x1b[A' ;;
            Down)    seq+='\x1b[B' ;;
            Right)   seq+='\x1b[C' ;;
            Left)    seq+='\x1b[D' ;;
            *)       die "unknown key: $key. Supported: Enter, Escape, Tab, C-c, C-d, C-z, C-l, C-a, C-e, C-u, C-k, C-w, Space, BSpace, Up, Down, Left, Right" ;;
        esac
    done
    printf "$seq" | wezterm cli send-text --pane-id "$target" --no-paste
    rm -f "${GUARD_PREFIX}-${target}"
    log_event ">" "$target" "keys" "$*"
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "keys" "pane_id=$target"
    fi
}

cmd_message() {
    require_args 2 $# "message"
    local target
    target="$(resolve_target "$1")"
    require_read "$target"
    check_lock "$target"
    require_wezterm
    shift
    local enter=false
    if [[ "${1:-}" == "--enter" ]]; then
        enter=true
        shift
    fi
    [[ $# -eq 0 ]] && die "message requires text argument"
    local pane_id="${WEZTERM_PANE:-unknown}"
    local label=""
    ensure_dirs
    if [[ -f "$LABEL_DIR/$pane_id" ]]; then
        label="$(cat "$LABEL_DIR/$pane_id")"
    fi
    local sender="${label:-pane:$pane_id}"
    printf '%s' "[wezterm-bridge from:${sender}] $*" | wezterm cli send-text --pane-id "$target" --no-paste
    if [[ "$enter" == "true" ]]; then
        sleep 0.05
        printf '\r' | wezterm cli send-text --pane-id "$target" --no-paste
    fi
    rm -f "${GUARD_PREFIX}-${target}"
    log_event ">" "$target" "message" ""
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "message" "pane_id=$target" "sender=$sender"
    fi
}

cmd_read() {
    require_args 1 $# "read"
    require_wezterm
    local target
    target="$(resolve_target "$1")"
    shift

    local new_mode=false
    local lines=50

    if [[ "${1:-}" == "--new" ]]; then
        new_mode=true
    elif [[ -n "${1:-}" ]]; then
        lines="$1"
        _require_posint "$lines" "lines must be a positive integer, got '$lines'"
    fi

    local content
    if $new_mode; then
        content="$(wezterm cli get-text --pane-id "$target" --start-line -500)"
        local new_content
        new_content="$(read_since_cursor "$target" "$content")"
        save_cursor "$target" "$content"
        touch "${GUARD_PREFIX}-${target}"
        log_event "<" "$target" "read" "--new"
        if [[ "$JSON_OUTPUT" == "true" ]]; then
            local encoded
            encoded="$(printf '%s' "$new_content" | jq -Rs '.')"
            printf '{"status":"ok","command":"read","pane_id":"%s","mode":"new","content":%s}\n' \
                "$target" "$encoded"
        else
            printf '%s\n' "$new_content"
        fi
    else
        local start_line="-${lines}"
        content="$(wezterm cli get-text --pane-id "$target" --start-line "$start_line")"
        save_cursor "$target" "$content"
        touch "${GUARD_PREFIX}-${target}"
        log_event "<" "$target" "read" "$lines"
        if [[ "$JSON_OUTPUT" == "true" ]]; then
            local encoded
            encoded="$(printf '%s' "$content" | jq -Rs '.')"
            printf '{"status":"ok","command":"read","pane_id":"%s","lines":%s,"content":%s}\n' \
                "$target" "$lines" "$encoded"
        else
            printf '%s\n' "$content"
        fi
    fi
}

cmd_list() {
    require_wezterm
    require_jq

    ensure_dirs

    if [[ "$JSON_OUTPUT" == "true" ]]; then
        local raw_json
        raw_json="$(wezterm cli list --format json)"
        local label_json="{"
        local first=true
        local f
        for f in "$LABEL_DIR"/*; do
            [[ -f "$f" ]] || continue
            local pid label_val
            pid="$(basename "$f")"
            label_val="$(cat "$f")"
            if $first; then first=false; else label_json+=","; fi
            label_json+="\"$pid\":\"$(json_escape "$label_val")\""
        done
        label_json+="}"
        printf '%s' "$raw_json" | jq -c --argjson labels "$label_json" \
            '[.[] | {pane_id: .pane_id, tab_id: .tab_id, title: .title, label: ($labels[(.pane_id | tostring)] // ""), cwd: .cwd}]'
        return
    fi

    printf "%-8s %-6s %-20s %-10s %s\n" "PANE_ID" "TAB" "TITLE" "LABEL" "CWD"
    printf "%-8s %-6s %-20s %-10s %s\n" "-------" "-----" "--------------------" "----------" "---"

    wezterm cli list --format json | jq -r '.[] | "\(.pane_id)\t\(.tab_id)\t\(.title)\t\(.cwd)"' | \
    while IFS=$'\t' read -r pane_id tab_id title cwd; do
        local label="-"
        if [[ -f "$LABEL_DIR/$pane_id" ]]; then
            label="$(cat "$LABEL_DIR/$pane_id")"
        fi
        cwd="${cwd/#$HOME/~}"
        if [[ ${#title} -gt 20 ]]; then
            title="${title:0:17}..."
        fi
        printf "%-8s %-6s %-20s %-10s %s\n" "$pane_id" "$tab_id" "$title" "$label" "$cwd"
    done
}

cmd_log() {
    ensure_dirs
    if [[ "${1:-}" == "--clear" ]]; then
        > "$LOG_FILE"
        echo "log cleared"
        return
    fi
    local tail_n=20
    if [[ "${1:-}" == "--tail" ]]; then
        tail_n="${2:-20}"
        _require_posint "$tail_n" "--tail requires a positive integer, got '$tail_n'"
    fi
    if [[ -f "$LOG_FILE" ]] && [[ -s "$LOG_FILE" ]]; then
        tail -n "$tail_n" "$LOG_FILE"
    else
        echo "(no log entries yet)"
    fi
}

cmd_wait() {
    require_args 1 $# "wait"
    require_wezterm
    local target
    target="$(resolve_target "$1")"
    shift

    local match="" quiet="" prompt=false
    local timeout=120 interval=2
    local conditions=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --match)   [[ $# -ge 2 ]] || die "--match requires an argument"
                       [[ -n "$2" ]] || die "--match requires a non-empty regex"
                       match="$2"; (( conditions += 1 )); shift 2 ;;
            --quiet)   [[ $# -ge 2 ]] || die "--quiet requires an argument"
                       quiet="$2"; (( conditions += 1 )); shift 2 ;;
            --prompt)  prompt=true; (( conditions += 1 )); shift ;;
            --timeout) [[ $# -ge 2 ]] || die "--timeout requires an argument"
                       timeout="$2"; shift 2 ;;
            --interval) [[ $# -ge 2 ]] || die "--interval requires an argument"
                        interval="$2"; shift 2 ;;
            *)         die "unknown flag '$1' for wait" ;;
        esac
    done

    if (( conditions == 0 )); then
        die "wait requires one of: --match <regex>, --quiet <secs>, --prompt"
    fi
    if (( conditions > 1 )); then
        die "wait accepts only one condition (got $conditions)"
    fi

    _require_posint "$timeout" "timeout must be a positive integer, got '$timeout'"
    _require_posint "$interval" "interval must be a positive integer, got '$interval'"

    $prompt && match='^[›$%#>] ?$'

    [[ -n "$quiet" ]] && _require_posint "$quiet" "quiet seconds must be a positive integer, got '$quiet'"

    local start_time
    start_time="$(date +%s)"
    local last_hash="" last_change_time="$start_time"

    while true; do
        local now
        now="$(date +%s)"
        local elapsed=$(( now - start_time ))

        if (( elapsed >= timeout )); then
            log_event ">" "$target" "wait" "timeout=${timeout}s"
            die "wait timed out after ${timeout}s"
        fi

        local content
        content="$(wezterm cli get-text --pane-id "$target" --start-line -50)"

        if [[ -n "$match" ]]; then
            local matched_line
            matched_line="$(printf '%s\n' "$content" | grep -E -- "$match" | tail -1)" || true
            if [[ -n "$matched_line" ]]; then
                touch "${GUARD_PREFIX}-${target}"
                log_event ">" "$target" "wait" "--match matched=${elapsed}s"
                if [[ "$JSON_OUTPUT" == "true" ]]; then
                    local encoded
                    encoded="$(printf '%s' "$matched_line" | jq -Rs '.')"
                    printf '{"status":"ok","command":"wait","pane_id":"%s","matched_line":%s,"elapsed_seconds":%d}\n' \
                        "$target" "$encoded" "$elapsed"
                else
                    printf '%s\n' "$matched_line"
                fi
                return 0
            fi
        fi

        if [[ -n "$quiet" ]]; then
            local current_hash
            current_hash="$(printf '%s' "$content" | cksum | cut -d' ' -f1)"
            if [[ "$current_hash" != "$last_hash" ]]; then
                last_hash="$current_hash"
                last_change_time="$now"
            fi
            local quiet_elapsed=$(( now - last_change_time ))
            if (( quiet_elapsed >= quiet )); then
                touch "${GUARD_PREFIX}-${target}"
                log_event ">" "$target" "wait" "--quiet ${quiet}s settled=${elapsed}s"
                if [[ "$JSON_OUTPUT" == "true" ]]; then
                    json_ok "wait" "pane_id=$target" "quiet_seconds=$quiet" "elapsed_seconds=$elapsed"
                else
                    echo "pane $target quiet for ${quiet}s (waited ${elapsed}s)"
                fi
                return 0
            fi
        fi

        sleep "$interval"
    done
}

cmd_spawn() {
    require_args 1 $# "spawn"
    require_wezterm
    local label="$1"; shift
    local cmd="" cwd="" direction="--bottom"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cmd)       [[ $# -ge 2 ]] || die "--cmd requires an argument"
                         cmd="$2"; shift 2 ;;
            --cwd)       [[ $# -ge 2 ]] || die "--cwd requires an argument"
                         cwd="$2"; shift 2 ;;
            --horizontal) direction="--right"; shift ;;
            *)           die "unknown flag '$1' for spawn" ;;
        esac
    done

    local args=("wezterm" "cli" "split-pane" "$direction")
    [[ -n "$cwd" ]] && args+=(--cwd "$cwd")
    if [[ -n "$cmd" ]]; then
        args+=(--)
        args+=("${SHELL:-/bin/sh}" "-lc" "$cmd")
    fi

    local new_pane_id
    new_pane_id="$("${args[@]}")"

    ensure_dirs
    _dedup_label "$label"
    printf '%s\n' "$label" > "$LABEL_DIR/$new_pane_id"

    log_event ">" "-" "spawn" "$label pane=$new_pane_id"
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "spawn" "pane_id=$new_pane_id" "label=$label"
    else
        echo "spawned pane $new_pane_id as '$label'"
    fi
}

cmd_lock() {
    require_args 1 $# "lock"
    require_wezterm
    local target
    target="$(resolve_target "$1")"
    local timeout_secs=30

    if [[ "${2:-}" == "--timeout" ]]; then
        [[ -n "${3:-}" ]] || die "--timeout requires an argument"
        timeout_secs="$3"
        _require_posint "$timeout_secs" "timeout must be a positive integer, got '$timeout_secs'"
    fi

    ensure_dirs
    if [[ -f "$LOCK_DIR/$target" ]]; then
        local owner ts existing_timeout
        IFS=: read -r owner ts existing_timeout < "$LOCK_DIR/$target"
        local now
        now="$(date +%s)"
        local expires=$(( ts + existing_timeout ))
        if (( now < expires )) && [[ "$owner" != "${WEZTERM_PANE:-}" ]]; then
            local remaining=$(( expires - now ))
            die "pane $target already locked by pane $owner (expires in ${remaining}s)"
        fi
    fi

    wezterm cli get-text --pane-id "$target" --start-line -50 >/dev/null
    touch "${GUARD_PREFIX}-${target}"

    local now
    now="$(date +%s)"
    printf '%s:%s:%s\n' "${WEZTERM_PANE:-?}" "$now" "$timeout_secs" > "$LOCK_DIR/$target"

    log_event ">" "$target" "lock" "timeout=${timeout_secs}s"
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "lock" "pane_id=$target" "timeout=$timeout_secs"
    else
        echo "locked pane $target (expires in ${timeout_secs}s)"
    fi
}

cmd_unlock() {
    require_args 1 $# "unlock"
    local target
    target="$(resolve_target "$1")"

    ensure_dirs
    local lock_file="$LOCK_DIR/$target"

    if [[ ! -f "$lock_file" ]]; then
        if [[ "$JSON_OUTPUT" == "true" ]]; then
            json_ok "unlock" "pane_id=$target" "was_locked=false"
        else
            echo "pane $target not locked"
        fi
        return
    fi

    local owner ts timeout_secs
    IFS=: read -r owner ts timeout_secs < "$lock_file"

    if [[ "$owner" != "${WEZTERM_PANE:-}" ]]; then
        local now
        now="$(date +%s)"
        local expires=$(( ts + timeout_secs ))
        if (( now < expires )); then
            die "pane $target locked by pane $owner, cannot unlock"
        fi
    fi

    rm -f "$lock_file"
    log_event ">" "$target" "unlock" ""
    if [[ "$JSON_OUTPUT" == "true" ]]; then
        json_ok "unlock" "pane_id=$target" "was_locked=true"
    else
        echo "unlocked pane $target"
    fi
}

cmd_doctor() {
    local ok=true

    echo "wezterm-bridge $VERSION diagnostics"
    echo "=================================="

    if command -v wezterm >/dev/null 2>&1; then
        echo "  [ok] wezterm found: $(wezterm --version)"
    else
        echo "  [!!] wezterm not found"
        ok=false
    fi

    if command -v jq >/dev/null 2>&1; then
        echo "  [ok] jq found: $(jq --version)"
    else
        echo "  [!!] jq not found — install with your package manager"
        ok=false
    fi

    if [[ -n "${WEZTERM_PANE:-}" ]]; then
        echo "  [ok] WEZTERM_PANE=$WEZTERM_PANE"
    else
        echo "  [!!] WEZTERM_PANE not set — not running inside WezTerm?"
        ok=false
    fi

    if wezterm cli list >/dev/null 2>&1; then
        if command -v jq >/dev/null 2>&1; then
            local pane_count
            pane_count="$(wezterm cli list --format json | jq 'length')"
            echo "  [ok] WezTerm connected — $pane_count pane(s) visible"
        else
            echo "  [ok] WezTerm connected (install jq for pane count)"
        fi
    else
        echo "  [!!] Cannot connect to WezTerm — is it running?"
        ok=false
    fi

    ensure_dirs
    local label_count
    label_count="$(find "$LABEL_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')"
    echo "  [ok] Label dir: $LABEL_DIR ($label_count label(s))"

    local guard_dir
    guard_dir="$(dirname "$GUARD_PREFIX")"
    local guard_count=0
    if [[ -d "$guard_dir" ]]; then
        guard_count="$(find "$guard_dir" -name 'read-*' -type f 2>/dev/null | wc -l | tr -d ' ')"
    fi
    echo "  [ok] Active read guards: $guard_count"

    echo ""
    if $ok; then
        echo "All checks passed."
    else
        echo "Some checks failed. Fix the issues above."
        exit 1
    fi
}

show_help() {
    cat <<'USAGE'
wezterm-bridge — AI agent communication through WezTerm panes

COMMANDS:
  list                        List all panes with IDs, titles, labels
  read <target> [lines]       Read pane content (default: 50 lines). Satisfies read guard.
  type <target> <text>        Send text to pane (no Enter). Requires prior read.
  keys <target> <key>...      Send special keys (Enter, Escape, C-c, Tab, etc). Requires prior read.
  message <target> <text>     Send prefixed message for agent-to-agent chat. Requires prior read.
  name <target> <label>       Label a pane for easy reference
  resolve <label>             Show pane ID for a label
  id                          Print current pane ID ($WEZTERM_PANE)
  wait <target> <condition>       Wait for pane content to match condition
                                  --match <regex>   Wait for regex match
                                  --quiet <secs>    Wait for output to settle
                                  --prompt          Wait for shell/agent prompt
                                  --timeout <secs>  Max wait (default: 120)
                                  --interval <secs> Poll interval (default: 2)
  spawn <label> [options]         Split pane, start command, label it
                                  --cmd <command>   Command to run (default: $SHELL)
                                  --cwd <dir>       Working directory
                                  --horizontal      Side-by-side split
  lock <target> [--timeout <s>]   Acquire pane lock (default: 30s expiry)
  unlock <target>                 Release pane lock
  log [--tail <n>] [--clear]      View or clear the audit log
  doctor                      Run diagnostics
  run <name|path> [VAR=val]   Run a workflow file (.wb)
                                  --check           Validate without executing

OPTIONS:
  --json                      Output results as JSON objects
  --version                   Print version
  --help, help                Show this help

EXAMPLES:
  wezterm-bridge list
  wezterm-bridge name 3 codex
  wezterm-bridge read codex 30
  wezterm-bridge message codex 'Please review src/auth.ts'
  wezterm-bridge keys codex Enter
USAGE
}

main() {
    if [[ "${1:-}" == "--json" ]]; then
        JSON_OUTPUT=true
        shift
    fi
    case "${1:-help}" in
        list)       shift; cmd_list "$@" ;;
        read)       shift; cmd_read "$@" ;;
        type)       shift; cmd_type "$@" ;;
        keys)       shift; cmd_keys "$@" ;;
        message)    shift; cmd_message "$@" ;;
        name)       shift; cmd_name "$@" ;;
        resolve)    shift; cmd_resolve "$@" ;;
        id)         cmd_id ;;
        spawn)      shift; cmd_spawn "$@" ;;
        lock)       shift; cmd_lock "$@" ;;
        unlock)     shift; cmd_unlock "$@" ;;
        doctor)     cmd_doctor ;;
        wait)       shift; cmd_wait "$@" ;;
        log)        shift; cmd_log "$@" ;;
        run)        shift; cmd_run "$@" ;;
        --version)  if [[ "$JSON_OUTPUT" == "true" ]]; then
                        json_ok "version" "version=$VERSION"
                    else
                        echo "wezterm-bridge $VERSION"
                    fi ;;
        help|--help) show_help ;;
        *)          die "unknown command '${1:-}'. Run: wezterm-bridge help" ;;
    esac
}

if [[ "${1:-}" == "--source-only" ]]; then
    return 0 2>/dev/null || true
else
    main "$@"
fi
